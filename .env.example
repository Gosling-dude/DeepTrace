# ─── DeepTrace Environment Configuration ───────────────
# Copy this file to .env and customize for your environment.

# ── Database ─────────────────────────────────────────────
# SQLite (development) — no setup required
DATABASE_URL=sqlite:///./deeptrace.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://deeptrace:password@localhost:5432/deeptrace

# ── JWT Authentication ───────────────────────────────────
# IMPORTANT: Generate a secure key for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-secret-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Application ──────────────────────────────────────────
APP_NAME=DeepTrace
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ── File Uploads ─────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,bmp,tiff

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ── Admin Seed Account ───────────────────────────────────
# Created automatically on first startup
ADMIN_EMAIL=admin@deeptrace.ai
ADMIN_PASSWORD=changeme123
ADMIN_NAME=DeepTrace Admin

# ── ML Models ────────────────────────────────────────────
MODEL_WEIGHTS_DIR=./models/weights
FALLBACK_TO_MOCK_MODEL=True
DEVICE=cpu
